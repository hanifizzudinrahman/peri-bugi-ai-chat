# =============================================================================
# App
# =============================================================================
APP_ENV=development             # development | production
APP_PORT=8003

# =============================================================================
# Internal Security
# =============================================================================
# Harus sama dengan AI_CHAT_INTERNAL_SECRET di peri-bugi-api
INTERNAL_SECRET=your_shared_secret_here

# =============================================================================
# LLM Provider — pilih salah satu, sisanya bisa dikosongkan
# =============================================================================
LLM_PROVIDER=ollama             # ollama | gemini | openai

# Ollama (dev lokal)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5

# Gemini (production)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# OpenAI (production)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# =============================================================================
# Qdrant Vector Store
# =============================================================================
QDRANT_URL=http://localhost:6333      # http://qdrant:6333 jika via Docker
QDRANT_API_KEY=                       # kosong untuk local, isi untuk Qdrant Cloud
QDRANT_COLLECTION=peri_bugi_dental    # nama collection

# =============================================================================
# Embedding Model
# =============================================================================
EMBEDDING_PROVIDER=local              # local | gemini | openai
# local: pakai sentence-transformers (gratis, jalan di CPU)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# =============================================================================
# External APIs
# =============================================================================
# URL peri-bugi-ai-cv untuk image inference
AI_CV_URL=http://host.docker.internal:8002

# =============================================================================
# LLM Settings
# =============================================================================
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60
