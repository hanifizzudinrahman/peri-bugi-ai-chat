# App
APP_ENV=development
APP_PORT=8003

# Security (harus sama dengan AI_CHAT_INTERNAL_SECRET di peri-bugi-api)
INTERNAL_SECRET=

# LLM Provider: ollama | gemini | openai
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma2:2b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=peri_bugi_dental
QDRANT_FAQ_COLLECTION=peri_bugi_faq

# Embedding
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=auto

# Redis (dari peri-bugi-api, exposed ke host)
# Aktifkan jika pakai Redis untuk rate limiting RnD endpoint
# REDIS_URL=redis://host.docker.internal:6379/0

# External
AI_CV_URL=
PERI_API_URL=http://host.docker.internal:8000

# RnD mode (matikan di production)
RND_MODE=True

# =============================================================================
# Langfuse Observability (optional)
# Default: DISABLED. Set LANGFUSE_ENABLED=true untuk aktifkan tracing.
# Lihat docs/LANGFUSE_INTEGRATION.md untuk detail.
#
# Pattern: graceful degradation - kalau Langfuse offline/unreachable,
# ai-chat tetap jalan normal, trace cuma di-drop.
# =============================================================================
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Internal Docker network URL (cross-stack via peri-bugi-shared network)
# Untuk akses dari laptop host (browser/curl): http://localhost:3100
LANGFUSE_HOST=http://langfuse-web:3000
